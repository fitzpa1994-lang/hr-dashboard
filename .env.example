# Zeabur / Node dashboard server
PORT=8080
NODE_ENV=production
HR_DASHBOARD_URL=https://sp-hr.zeabur.app

# Required dashboard auth
HR_DASHBOARD_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-string

# Required n8n Dashboard API proxy
N8N_HR_WEBHOOK_URL=https://your-n8n-host/webhook/hr-dashboard
N8N_HR_TOKEN=replace-with-current-n8n-token

# Optional
SESSION_TTL_MS=28800000
N8N_PROXY_TIMEOUT_MS=10000
